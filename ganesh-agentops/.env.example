# ── Application ─────────────────────────────────────────────────
APP_NAME=Ganesh AgentOps
DEBUG=true

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/agentops.db

# ── CORS (JSON array) ────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── AI API Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Telegram Integration ─────────────────────────────────────────
# How to get a token:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot, choose a name and username (must end in _bot)
#   3. Copy the token BotFather gives you into TELEGRAM_BOT_TOKEN
#   4. (Optional) Send /start to your bot, then visit:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      to find your TELEGRAM_CHAT_ID in the "chat" object.
#
# Leave blank to disable Telegram — the backend starts normally without it.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
# Set to true on dev machines with SSL certificate issues (corporate proxy, etc.)
# Never set to true in production
TELEGRAM_SKIP_SSL_VERIFY=false
